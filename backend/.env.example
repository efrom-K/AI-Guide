# Claude API
ANTHROPIC_API_KEY=

# OpenAI-compatible provider (LM Studio / OpenRouter / vLLM ...)
#   LM Studio:  OPENAI_BASE_URL=http://localhost:1234/v1   OPENAI_API_KEY=lm-studio
#   OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1   OPENAI_API_KEY=sk-or-...
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=
OPENAI_MODEL=
# optional per-role overrides (else OPENAI_MODEL):
OPENAI_MODEL_SCORER=
OPENAI_MODEL_NARRATOR=
OPENAI_MODEL_COMPANION=
OPENAI_MODEL_LANDMARK=

# Model routing (override defaults if needed)
MODEL_SCORER=claude-haiku-4-5
MODEL_NARRATOR=claude-sonnet-4-6
MODEL_COMPANION=claude-sonnet-4-6
MODEL_LANDMARK=claude-opus-4-8

# Geo
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Behaviour
DEFAULT_LANGUAGE=ru
DEFAULT_RADIUS_M=80
MAX_RADIUS_M=500

# State store: empty => in-memory; otherwise redis url e.g. redis://localhost:6379/0
REDIS_URL=

# Server
HOST=127.0.0.1
PORT=8000

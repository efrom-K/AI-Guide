# Copy to .env and fill in OPENAI_API_KEY. Never commit .env (it holds the key).
# These are the production-ready values for a real walk (cloud LLM + real OSM + facts).

# --- LLM: OpenRouter -> DeepSeek V3 on all roles ----------------------------
# IMPORTANT (region block): OpenRouter geo-blocks OpenAI / Anthropic / Google
# (Gemini) from some host regions (e.g. RU) -> every call returns HTTP 403
# "This model is not available in your region." DeepSeek V3 is reachable there
# and handles strict json_schema (Scorer) + multilingual narration well, so it
# is the production default. On an unrestricted host you may switch OPENAI_MODEL
# back to google/gemini-3.5-flash (then restore the reasoning cap below).
AGENT_BACKEND=openai
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=                       # sk-or-... (required)
OPENAI_MODEL=deepseek/deepseek-chat
OPENAI_MODEL_SCORER=
OPENAI_MODEL_NARRATOR=
OPENAI_MODEL_COMPANION=
OPENAI_MODEL_LANDMARK=
OPENAI_MODEL_ENRICHER=
# DeepSeek V3 is not a reasoning model -> leave the cap off (ignored anyway).
# (For Gemini set EFFORT=low and MAX_TOKENS=64 to keep its CoT out of the prose.)
OPENAI_REASONING_EFFORT=
OPENAI_REASONING_MAX_TOKENS=0
OPENAI_PROMPT_CACHE=true
OPENAI_PRICE_IN_PER_MTOK=0.3          # DeepSeek V3 ballpark; provider-reported cost is authoritative
OPENAI_PRICE_OUT_PER_MTOK=0.9
USD_SESSION_BUDGET=25                 # soft warning only — set a hard cap in the OpenRouter dashboard

# Anthropic (only if AGENT_BACKEND=anthropic)
ANTHROPIC_API_KEY=

# --- Geo: real places from OpenStreetMap ------------------------------------
GEO_SOURCE=overpass                   # MUST be "overpass" for a real walk ("fixture" = Red Square demo only)
# Public overpass-api.de is often rate-limited/blocked; this mirror is reliable:
OVERPASS_URL=https://maps.mail.ru/osm/tools/overpass/api/interpreter

# --- Fact enrichment: real WebSearch (OpenRouter web plugin) -----------------
ENRICHMENT_SOURCE=websearch           # "mock" = fixtures (offline/tests)
WEB_SEARCH_MAX_RESULTS=2              # web results per place (OpenRouter bills per result)
WEB_SEARCH_MAX_TOKENS=400
ENRICH_TOP_K=2
ENRICH_TIMEOUT_S=9.0                  # web search needs ~5-7s; too low => no facts, only names
ENRICH_MIN_WEIGHT=0.0                # wiki facts are free; gates only the PAID fallback for
                                     # non-wiki places (0 = search all; raise to save cost)
ENRICH_CACHE_PATH=.enrich_cache.json  # docker-compose overrides this to a volume path

# --- STT (voice barge-in): local Whisper ------------------------------------
STT_BACKEND=faster_whisper            # "mock" returns a canned transcript (no model download)
WHISPER_MODEL_SIZE=small              # tiny|base|small|medium — smaller = faster on CPU
WHISPER_DEVICE=cpu                    # "cuda" needs a GPU + CUDA libs in the image
WHISPER_COMPUTE_TYPE=int8

# --- Behaviour --------------------------------------------------------------
DEFAULT_LANGUAGE=ru                   # the app overrides this per session anyway
DEFAULT_RADIUS_M=80
MAX_RADIUS_M=500

# State store: empty => in-memory; otherwise a redis url e.g. redis://localhost:6379/0
REDIS_URL=
SESSION_TTL_S=3600                     # evict idle in-memory sessions after this (0 = never)
MAX_SESSIONS=2000                     # LRU cap on in-memory sessions (0 = unbounded)

# --- Security & spend limits (protect the public /ws) -----------------------
# Shared access token for /ws. Empty => OPEN (dev). In prod set a long random value;
# the clients must be (re)built with the SAME token (WS_TOKEN dart-define / injected
# into the web client) — back end + clients roll out together.
WS_TOKEN=
MAX_CONNECTIONS_PER_IP=8               # concurrent WS per IP. Raise (~32) while testers share a NAT.
# Hard spend ceiling (USD, cumulative process spend). 0 = off. Once hit, LLM calls
# are blocked (guide goes silent) — in-app backstop on top of the OpenRouter dashboard cap.
# STRONGLY RECOMMENDED on any public/paid deploy: the /ws is open, so without a cap an
# abuser can drive unbounded LLM/web-search cost. Set a value AND a monthly cap on the
# provider dashboard. The backend logs a warning at startup when this is 0 on a paid backend.
USD_HARD_CAP=0
MAX_UTTERANCE_CHARS=2000
MAX_AUDIO_B64_CHARS=8000000           # ~6 MB decoded audio clip ceiling
MAX_WS_FRAME_CHARS=8065536            # hard cap on one inbound WS frame (pre-parse, anti-DoS)
STATS_TOKEN=                          # admin token for GET /stats; empty => /stats disabled

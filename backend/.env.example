# Copy to .env and fill in OPENAI_API_KEY. Never commit .env (it holds the key).
# These are the production-ready values for a real walk (cloud LLM + real OSM + facts).

# --- LLM: OpenRouter -> Gemini 3.5 Flash on all roles -----------------------
AGENT_BACKEND=openai
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=                       # sk-or-... (required)
OPENAI_MODEL=google/gemini-3.5-flash
OPENAI_MODEL_SCORER=
OPENAI_MODEL_NARRATOR=
OPENAI_MODEL_COMPANION=
OPENAI_MODEL_LANDMARK=
OPENAI_MODEL_ENRICHER=
# Gemini 3.x requires reasoning; cap it for the prose/extraction roles
OPENAI_REASONING_EFFORT=low
OPENAI_REASONING_MAX_TOKENS=64
OPENAI_PROMPT_CACHE=true
OPENAI_PRICE_IN_PER_MTOK=1.5
OPENAI_PRICE_OUT_PER_MTOK=9.0
USD_SESSION_BUDGET=25                 # soft warning only — set a hard cap in the OpenRouter dashboard

# Anthropic (only if AGENT_BACKEND=anthropic)
ANTHROPIC_API_KEY=

# --- Geo: real places from OpenStreetMap ------------------------------------
GEO_SOURCE=overpass                   # MUST be "overpass" for a real walk ("fixture" = Red Square demo only)
# Public overpass-api.de is often rate-limited/blocked; this mirror is reliable:
OVERPASS_URL=https://maps.mail.ru/osm/tools/overpass/api/interpreter

# --- Fact enrichment: real WebSearch (OpenRouter web plugin) -----------------
ENRICHMENT_SOURCE=websearch           # "mock" = fixtures (offline/tests)
WEB_SEARCH_MAX_RESULTS=3              # web results per place (OpenRouter bills per result)
WEB_SEARCH_MAX_TOKENS=400
ENRICH_TOP_K=3
ENRICH_TIMEOUT_S=6.0
ENRICH_CACHE_PATH=.enrich_cache.json  # docker-compose overrides this to a volume path

# --- STT (voice barge-in): local Whisper ------------------------------------
STT_BACKEND=faster_whisper            # "mock" returns a canned transcript (no model download)
WHISPER_MODEL_SIZE=small              # tiny|base|small|medium — smaller = faster on CPU
WHISPER_DEVICE=cpu                    # "cuda" needs a GPU + CUDA libs in the image
WHISPER_COMPUTE_TYPE=int8

# --- Behaviour --------------------------------------------------------------
DEFAULT_LANGUAGE=ru                   # the app overrides this per session anyway
DEFAULT_RADIUS_M=80
MAX_RADIUS_M=500

# State store: empty => in-memory; otherwise a redis url e.g. redis://localhost:6379/0
REDIS_URL=
